# Database (e.g. Neon PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Better Auth — use a long random string (32+ chars)
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
# Server base URL (must match how users open the app)
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Public URL for links inside emails (invites, notifications). Production example:
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Email — Resend (https://resend.com) free tier: transactional emails
# Create an API key, verify a domain OR use Resend's test sender for development:
RESEND_API_KEY=""
EMAIL_FROM="AgencyOS <onboarding@resend.dev>"
